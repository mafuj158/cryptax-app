{
  "expo": {
    "name": "cryptax-app",
    "slug": "cryptax-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cryptaxapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "@/assets/fonts/SFProDisplayBlack.ttf",
            "@/assets/fonts/SFProDisplayBold.ttf",
            "@/assets/fonts/SFProDisplayHeavy.ttf",
            "@/assets/fonts/SFProDisplayLight.ttf",
            "@/assets/fonts/SFProDisplayMedium.ttf",
            "@/assets/fonts/SFProDisplayRegular.ttf",
            "@/assets/fonts/SFProDisplaySemibold.ttf",
            "@/assets/fonts/SFProDisplayThin.ttf",
            "@/assets/fonts/SFProDisplayUltralight.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
